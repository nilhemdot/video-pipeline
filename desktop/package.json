{
  "name": "tobu-desktop",
  "version": "1.0.0",
  "description": "TOBU Knowledge Vault Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.tobu.desktop",
    "productName": "TOBU Vault",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "package.json",
      "ui/**/*"
    ],
    "extraResources": [
      {
        "from": "../dist/tobu-vault-engine",
        "to": "engine",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0"
  }
}
